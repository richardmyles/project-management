{
  "name": "my-projects",
  "version": "1.0.0",
  "description": "Personal project management — goals tracking and progress reporting",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "create-icon": "node scripts/create-icon.js",
    "dist": "node scripts/create-icon.js && node scripts/copy-skill.js && electron-builder --win --x64"
  },
  "author": "My Projects",
  "private": true,
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "adm-zip": "^0.5.16",
    "docx": "^9.6.1",
    "express": "^4.21.0",
    "mammoth": "^1.8.0",
    "multer": "^1.4.5-lts.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.myprojects.app",
    "productName": "My Projects",
    "icon": "build/icon.ico",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "server.js",
      "public/**/*",
      "package.json",
      "node_modules/**/*",
      "!node_modules/.cache/**/*",
      "!dist/**/*"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "My Projects"
    },
    "portable": {
      "artifactName": "MyProjects-portable.exe"
    }
  }
}
