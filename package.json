{
  "name": "my-projects",
  "version": "1.0.3",
  "description": "Personal project management tool — tracks projects, milestones, goals, risks, and progress reports",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "dist": "electron-builder --win --x64",
    "import-goals": "node scripts/import-goals.js"
  },
  "author": "",
  "private": true,
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "adm-zip": "^0.5.16",
    "cheerio": "^1.2.0",
    "docx": "^9.6.1",
    "electron-updater": "^6.3.9",
    "express": "^4.21.0",
    "mammoth": "^1.8.0",
    "multer": "^1.4.5-lts.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.myprojects.app",
    "productName": "My Projects",
    "publish": [
      {
        "provider": "github",
        "owner": "richardmyles",
        "repo": "project-management"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "server.js",
      "public/**/*",
      "package.json",
      "node_modules/**/*",
      "!node_modules/.cache/**/*",
      "!dist/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "My Projects"
    },
    "portable": {
      "artifactName": "MyProjects-portable.exe"
    }
  }
}
