# AI Integration (required for AI features)
# Option A: Standard Anthropic API key
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Option B: Custom API gateway (e.g. corporate proxy)
# AI_API_KEY=your-api-key-here
# AI_BASE_URL=https://your-gateway.example.com
# AI_MODEL=claude-sonnet-4-5

# Option C: CLI token command (e.g. corporate SSO CLI)
# AI_TOKEN_CMD=your-cli-tool token

# Obsidian vault integration (optional)
# OBSIDIAN_VAULT=C:\path\to\your\vault
